# nucleo environment variables
# Copy this file to .env and fill in your values.

# Authentication — set this to skip `nucleo auth login`
NUCLEO_TOKEN=

# Project context overrides
NUCLEO_PROJECT_ID=
NUCLEO_ENV_ID=
NUCLEO_API_KEY=
NUCLEO_STAGE=

# Service URL overrides (keys match your config.json presets)
# NUCLEO_AUTH_URL=https://auth.example.com/api/v2
# NUCLEO_API_URL=https://api.example.com/api/v1

# Templates directory override
# NUCLEO_TEMPLATES_DIR=./templates
